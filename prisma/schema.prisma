// Prisma schema for the HMCTS Task API.
//
// SQLite is used here for simplicity: zero-config, file-based, and well-suited
// for a take-home / single-process demo. The Task model and its TaskStatus enum
// are kept narrow on purpose - any additional metadata (assignee, case ref, etc.)
// would land here as future migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([dueDate])
}
